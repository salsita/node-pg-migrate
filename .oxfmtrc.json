{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [".claude/**", "CHANGELOG.md"],
  "singleQuote": true,
  "trailingComma": "es5",
  "printWidth": 80,
  "sortPackageJson": false,
  "sortImports": {
    "groups": [
      ["builtin", "external", "internal"],
      { "newlinesBetween": false },
      ["parent", "sibling", "index"]
    ],
    "newlinesBetween": false,
    "order": "asc",
    "ignoreCase": true
  },
  "overrides": [
    {
      "files": ["*.json5"],
      "options": {
        "quoteProps": "preserve",
        "singleQuote": false,
        "trailingComma": "none"
      }
    }
  ]
}
